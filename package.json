{
  "name": "vue3-admin-layout",
  "type": "module",
  "version": "1.0.4",
  "packageManager": "pnpm@10.33.4",
  "description": "一个灵活的 Vue 管理后台布局组件",
  "author": "YCH",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coderych/vue3-admin-layout.git"
  },
  "keywords": [
    "vue",
    "admin",
    "layout",
    "dashboard",
    "ui"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dist/style.css": "./dist/vue3-admin-layout.css"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:fix": "eslint . --fix --cache",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@vueuse/core": "^13.1.0",
    "simplebar-vue": "^2.4.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.13.0",
    "@iconify/json": "^2.2.336",
    "@iconify/utils": "^2.3.0",
    "@types/node": "^22.15.17",
    "@unocss/eslint-plugin": "^66.1.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.26.0",
    "eslint-plugin-format": "^1.0.1",
    "happy-dom": "^15.7.4",
    "less": "^4.3.0",
    "typescript": "^5.8.3",
    "unocss": "^66.1.1",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.1.4",
    "vue-tsc": "^2.2.8"
  }
}
